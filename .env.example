# ==============================================================================
# BASE DE DATOS
# ==============================================================================

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myapp_db"

# ==============================================================================
# AUTENTICACION (Auth.js v5)
# ==============================================================================

# Clave secreta para firmar tokens JWT. Generar con:
# openssl rand -base64 32
AUTH_SECRET=""

# URL base de la aplicacion. En produccion, la URL real del dominio.
NEXTAUTH_URL="http://localhost:3000"

# ==============================================================================
# EMAILS
# ==============================================================================

# Email que recibe las alertas del formulario de contacto (email del administrador)
ADMIN_EMAIL=""

# API Key de Brevo (ex-Sendinblue). Obtener en:
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""

# Email verificado en Brevo desde el que se envian los correos
BREVO_SENDER_EMAIL=""

# Nombre que aparece como remitente en los emails
BREVO_SENDER_NAME=""

# ==============================================================================
# CLOUDINARY (imagenes)
# ==============================================================================

# Cloud name de tu cuenta Cloudinary
CLOUDINARY_CLOUD_NAME=""

# API Key (solo para uso en servidor)
CLOUDINARY_API_KEY=""

# API Secret (solo para uso en servidor, NUNCA exponer al cliente)
CLOUDINARY_API_SECRET=""

# Cloud name para uso en el navegador (componentes next-cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Upload preset para subidas sin firma desde el cliente
# Crear en: Cloudinary Dashboard > Settings > Upload > Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Carpeta en Cloudinary donde se guardan las imagenes del proyecto
# Usar el nombre del proyecto (ej: mi-app, mi-app/blog)
CLOUDINARY_FOLDER="mi-app"